# Logging configuration (optional)
# LOG_MAX_SIZE_MB=50                    # Max file size before rotation (default: 50)
# LOG_RETENTION_DAYS=7                  # Days to retain logs (default: 7)
# LOG_COMPRESSION_AGE_DAYS=3            # Days before compression (default: 3)
# LOG_MAINTENANCE_SECRET=your-secret    # Secret for maintenance API (optional)