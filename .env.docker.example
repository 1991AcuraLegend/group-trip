# Docker Compose Environment Configuration
# Copy this to .env.docker and set all required values before deployment

# PostgreSQL Configuration
DB_USER=traveler
DB_PASSWORD=
DB_NAME=travelplanner
DB_PORT=5432

# Next.js Configuration
APP_PORT=3000
NODE_ENV=production

# NextAuth Configuration
NEXTAUTH_URL=https://your-domain.example
NEXTAUTH_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=TravelPlanner <noreply@mail.cbesmer.com>
# Use a verified Resend sender/domain in production.

# Logging maintenance API protection (optional but recommended)
LOG_MAINTENANCE_SECRET=

# To use this file, run:
# docker-compose --env-file .env.docker up
